<Window x:Class="ScrcpyGUI.WPF.Views.FloatingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:ScrcpyGUI.WPF.ViewModels"
        mc:Ignorable="d"
        Title="快捷工具" 
        Height="160" 
        Width="380"
        WindowStyle="SingleBorderWindow"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    
    <Window.DataContext>
        <viewModels:FloatingViewModel />
    </Window.DataContext>

    <Grid Background="White" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center">
            <Button Content="📷 截图" 
                    Command="{Binding TakeScreenshotCommand}"
                    Margin="5"
                    Padding="10,5" />
            <Button Content="🔘 电源" 
                    Command="{Binding PowerKeyCommand}"
                    Margin="5"
                    Padding="10,5" />
            <Button Content="🏠 首页" 
                    Command="{Binding HomeKeyCommand}"
                    Margin="5"
                    Padding="10,5" />
            <Button Content="↩️ 返回" 
                    Command="{Binding BackKeyCommand}"
                    Margin="5"
                    Padding="10,5" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <TextBox x:Name="InputTextBox"
                     Grid.Column="0"
                     Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                     Padding="8,5"
                     KeyDown="InputTextBox_KeyDown" />
            
            <Button x:Name="SendButton"
                    Grid.Column="1"
                    Content="发送"
                    Command="{Binding SendTextCommand}"
                    Margin="5,0,0,0"
                    Padding="15,5" />
        </Grid>

        <TextBlock x:Name="NotificationText"
                  Grid.Row="2"
                  Text=""
                  Foreground="#007ACC"
                  FontWeight="Bold"
                  HorizontalAlignment="Center"
                  Margin="0,10,0,0" />
    </Grid>
</Window>
