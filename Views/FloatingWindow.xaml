<Window x:Class="ScrcpyGUI.WPF.Views.FloatingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:ScrcpyGUI.WPF.ViewModels"
        mc:Ignorable="d"
        Title="快捷工具" 
        Height="450" 
        Width="160"
        MinHeight="400"
        MinWidth="120"
        WindowStyle="SingleBorderWindow"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResize">
    
    <Window.DataContext>
        <viewModels:FloatingViewModel />
    </Window.DataContext>

    <Grid Background="White" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" 
                    Orientation="Vertical" 
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <Button Content="📷 截图" 
                    Command="{Binding TakeScreenshotCommand}"
                    Margin="3"
                    Padding="5,3"
                    Width="100" />
            <Button Content="🔘 电源" 
                    Command="{Binding PowerKeyCommand}"
                    Margin="3"
                    Padding="5,3"
                    Width="100" />
            <Button Content="🏠 首页" 
                    Command="{Binding HomeKeyCommand}"
                    Margin="3"
                    Padding="5,3"
                    Width="100" />
            <Button Content="↩️ 返回" 
                    Command="{Binding BackKeyCommand}"
                    Margin="3"
                    Padding="5,3"
                    Width="100" />
            <Button Content="🔊 音量+" 
                    Command="{Binding VolumeUpCommand}"
                    Margin="3"
                    Padding="5,3"
                    Width="100" />
            <Button Content="🔇 音量-" 
                    Command="{Binding VolumeDownCommand}"
                    Margin="3"
                    Padding="5,3"
                    Width="100" />
            <Button Content="📋 菜单" 
                    Command="{Binding MenuKeyCommand}"
                    Margin="3"
                    Padding="5,3"
                    Width="100" />
            <Button Content="📱 多任务" 
                    Command="{Binding RecentAppsCommand}"
                    Margin="3"
                    Padding="5,3"
                    Width="100" />
            <Button Content="📢 通知栏" 
                    Command="{Binding ExpandNotificationCommand}"
                    Margin="3"
                    Padding="5,3"
                    Width="100" />
        </StackPanel>

        <TextBlock x:Name="NotificationText"
                  Grid.Row="1"
                  Text=""
                  Foreground="#007ACC"
                  FontWeight="Bold"
                  HorizontalAlignment="Center"
                  Margin="0,10,0,0" />
    </Grid>
</Window>
