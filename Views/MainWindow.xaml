<Window x:Class="ScrcpyGUI.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:ScrcpyGUI.WPF.ViewModels"
        xmlns:models="clr-namespace:ScrcpyGUI.WPF.Models"
        xmlns:local="clr-namespace:ScrcpyGUI.WPF.Views"
        xmlns:converters="clr-namespace:ScrcpyGUI.WPF.Converters"
        mc:Ignorable="d"
        Title="Scrcpy GUI" Height="700" Width="900"
        MinHeight="500" MinWidth="800">
    <Window.DataContext>
        <viewModels:MainViewModel />
    </Window.DataContext>
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ToolBar Grid.Row="0" Height="40">
            <Button Content="🏠 主界面" Command="{Binding GoBackToMainCommand}" Margin="5,0" Padding="10,5">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSettingsPanelVisible}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsAboutPanelVisible}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="🔄 刷新设备" Command="{Binding RefreshDevicesCommand}" Margin="5,0" Padding="10,5">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSettingsPanelVisible}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsAboutPanelVisible}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="📡 无线连接" Command="{Binding ShowWifiConnectWindowCommand}" Margin="5,0" Padding="10,5">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSettingsPanelVisible}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsAboutPanelVisible}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Separator />
            <Button Content="⚙️ 设置" Command="{Binding ToggleSettingsCommand}" Margin="5,0" Padding="10,5">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSettingsPanelVisible}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsAboutPanelVisible}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="ℹ️ 关于" Command="{Binding ShowAboutWindowCommand}" Margin="5,0" Padding="10,5">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSettingsPanelVisible}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsAboutPanelVisible}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </ToolBar>

        <Grid Grid.Row="1">
            <Grid Name="MainPanel">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSettingsPanelVisible}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsAboutPanelVisible}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" MinWidth="150" />
                    <ColumnDefinition Width="*" MinWidth="200" />
                    <ColumnDefinition Width="200" MinWidth="150" />
                </Grid.ColumnDefinitions>

                <GroupBox Header="设备列表" Grid.Column="0" Margin="5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <ListBox ItemsSource="{Binding Devices}" 
                                 SelectedItem="{Binding SelectedDevice}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DeviceName}" FontWeight="Bold" />
                                        <TextBlock Text="{Binding SerialNumber}" FontSize="10" Foreground="Gray" />
                                        <TextBlock>
                                            <Run Text="{Binding ConnectionType}" />
                                            <Run Text=" - " />
                                            <Run Text="{Binding Status}" />
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </GroupBox>

                <GroupBox Header="控制面板" Grid.Column="1" Margin="5">
                    <StackPanel VerticalAlignment="Center" Margin="10">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                            <Button Content="▶️ 启动投屏" 
                                    Command="{Binding StartScrcpyCommand}"
                                    Height="40" FontSize="14" Margin="0,0,5,0" Padding="15,0"
                                    IsEnabled="{Binding StartScrcpyCommand.CanExecute, RelativeSource={RelativeSource Self}}" />
                            <Button Content="⏹️ 停止投屏" 
                                    Command="{Binding StopScrcpyCommand}"
                                    Height="40" FontSize="14" Margin="5,0,5,0" Padding="15,0"
                                    IsEnabled="{Binding StopScrcpyCommand.CanExecute, RelativeSource={RelativeSource Self}}" />
                            <Button Content="🔧 快捷工具" 
                                    Command="{Binding ToggleFloatingWindowCommand}"
                                    Height="40" FontSize="14" Margin="5,0,0,0" Padding="15,0" />
                        </StackPanel>
                        
                        <Separator Margin="0,10" />

                        <TextBlock Text="ADB 命令执行" FontWeight="Bold" Margin="0,5" />
                        
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            
                            <TextBox x:Name="AdbCommandTextBox"
                                     Grid.Column="0"
                                     Text="{Binding AdbCommandText, UpdateSourceTrigger=PropertyChanged}"
                                     Height="60"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Padding="5"
                                     FontFamily="Consolas" />
                            
                            <Button Grid.Column="1"
                                    Content="执行"
                                    Command="{Binding ExecuteAdbCommand}"
                                    IsEnabled="{Binding !IsAdbCommandExecuting}"
                                    Margin="5,0,0,0"
                                    Padding="15,5"
                                    Width="70" />
                            
                            <Button Grid.Column="2"
                                    Content="清除"
                                    Command="{Binding ClearAdbCommand}"
                                    Margin="5,0,0,0"
                                    Padding="15,5"
                                    Width="70" />
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock Text="状态: " FontWeight="Bold" />
                            <TextBlock Text="{Binding AdbCommandStatus}" />
                        </StackPanel>

                        <GroupBox Header="输出结果" Margin="0,10,0,0">
                            <TextBox Text="{Binding AdbCommandOutput}"
                                     IsReadOnly="True"
                                     Height="150"
                                     VerticalScrollBarVisibility="Auto"
                                     Padding="5"
                                     FontFamily="Consolas"
                                     FontSize="11"
                                     Background="#F5F5F5" />
                        </GroupBox>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="参数配置" Grid.Column="2" Margin="5">
                    <ScrollViewer>
                        <StackPanel Margin="10">
                            <TextBlock Text="分辨率 (0=不限制)" Margin="0,5" />
                            <ComboBox SelectedValue="{Binding Config.MaxSize}" 
                                      SelectedValuePath="Tag"
                                      Margin="0,0,0,10">
                                <ComboBoxItem Content="0=不限制" Tag="0" />
                                <ComboBoxItem Content="1920" Tag="1920" />
                                <ComboBoxItem Content="1080" Tag="1080" />
                                <ComboBoxItem Content="720" Tag="720" />
                                <ComboBoxItem Content="540" Tag="540" />
                            </ComboBox>

                            <TextBlock Text="码率 (Mbps)" Margin="0,5" />
                            <ComboBox SelectedValue="{Binding Config.BitRate}" 
                                      SelectedValuePath="Tag"
                                      Margin="0,0,0,10">
                                <ComboBoxItem Content="8" Tag="8" />
                                <ComboBoxItem Content="12" Tag="12" />
                                <ComboBoxItem Content="16" Tag="16" />
                                <ComboBoxItem Content="20" Tag="20" />
                                <ComboBoxItem Content="24" Tag="24" />
                                <ComboBoxItem Content="32" Tag="32" />
                            </ComboBox>

                            <TextBlock Text="帧率 (fps)" Margin="0,5" />
                            <ComboBox SelectedValue="{Binding Config.MaxFps}" 
                                      SelectedValuePath="Tag"
                                      Margin="0,0,0,10">
                                <ComboBoxItem Content="30" Tag="30" />
                                <ComboBoxItem Content="60" Tag="60" />
                                <ComboBoxItem Content="120" Tag="120" />
                            </ComboBox>

                            <CheckBox Content="启用音频" IsChecked="{Binding Config.EnableAudio}" Margin="0,5" />
                            <CheckBox Content="启用触控" IsChecked="{Binding Config.EnableTouchControl}" Margin="0,5" />
                            <CheckBox Content="无边框模式" IsChecked="{Binding Config.WindowBorderless}" Margin="0,5" />
                            <CheckBox Content="窗口置顶" IsChecked="{Binding Config.WindowAlwaysOnTop}" Margin="0,5" />
                            <CheckBox Content="启动时录屏" IsChecked="{Binding Config.RecordOnStart}" Margin="0,5" />
                            <CheckBox Content="黑屏启动" IsChecked="{Binding Config.BlackScreenOnStart}" Margin="0,5" />
                            <CheckBox Content="显示触摸" IsChecked="{Binding Config.ShowTouch}" Margin="0,5" />
                            <CheckBox Content="旋转镜像" IsChecked="{Binding Config.RotateMirror}" Margin="0,5" />
                            <CheckBox Content="全屏启动" IsChecked="{Binding Config.FullscreenOnStart}" Margin="0,5" />
                            <CheckBox Content="关闭后锁屏" IsChecked="{Binding Config.LockScreenOnClose}" Margin="0,5" />
                        </StackPanel>
                    </ScrollViewer>
                </GroupBox>
            </Grid>

            <Grid Name="SettingsPanel">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSettingsPanelVisible}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsAboutPanelVisible}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <ScrollViewer>
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="设置" FontSize="16" FontWeight="Bold" Margin="0,0,0,20" />

                        <GroupBox Grid.Row="1" Header="路径设置" Margin="0,0,0,15">
                            <StackPanel Margin="10">
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text="Scrcpy 可执行文件：" VerticalAlignment="Center" Width="150" />
                                    <TextBox Text="{Binding Config.ScrcpyPath, UpdateSourceTrigger=PropertyChanged}" 
                                             Width="300" Margin="0,0,10,0" />
                                    <Button Content="浏览..." 
                                            Command="{Binding BrowseScrcpyCommand}"
                                            Padding="15,5" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text="ADB 可执行文件：" VerticalAlignment="Center" Width="150" />
                                    <TextBox Text="{Binding Config.AdbPath, UpdateSourceTrigger=PropertyChanged}" 
                                             Width="300" Margin="0,0,10,0" />
                                    <Button Content="浏览..." 
                                            Command="{Binding BrowseAdbCommand}"
                                            Padding="15,5" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text="截图保存路径：" VerticalAlignment="Center" Width="150" />
                                    <TextBox Text="{Binding Config.ScreenshotSavePath, UpdateSourceTrigger=PropertyChanged}" 
                                             Width="300" Margin="0,0,10,0" />
                                    <Button Content="浏览..." 
                                            Command="{Binding BrowseScreenshotPathCommand}"
                                            Padding="15,5" />
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Grid.Row="2" Header="悬浮窗设置" Margin="0,0,0,15">
                            <StackPanel Margin="10">
                                <CheckBox Content="启用智能输入悬浮窗" 
                                          IsChecked="{Binding Config.EnableInputFloatingWindow}"
                                          Margin="0,5" />
                                <CheckBox Content="检测到输入法自动弹出悬浮窗" 
                                          IsChecked="{Binding Config.AutoShowOnKeyboard}"
                                          Margin="0,5" />
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Grid.Row="3" Header="快捷键设置" Margin="0,0,0,15">
                            <StackPanel Margin="10">
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text="发送到设备：" VerticalAlignment="Center" Width="180" />
                                    <local:ShortcutKeyBox ShortcutKey="{Binding Config.SendToDeviceShortcutKey}" Width="200" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text="发送+回车：" VerticalAlignment="Center" Width="180" />
                                    <local:ShortcutKeyBox ShortcutKey="{Binding Config.SendWithEnterShortcutKey}" Width="200" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text="显示悬浮窗：" VerticalAlignment="Center" Width="180" />
                                    <local:ShortcutKeyBox ShortcutKey="{Binding Config.ShowFloatingWindowShortcutKey}" Width="200" />
                                </StackPanel>
                                <Separator Margin="10,0" />
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text="返回：" VerticalAlignment="Center" Width="180" />
                                    <local:ShortcutKeyBox ShortcutKey="{Binding Config.BackKeyShortcut}" Width="200" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text="主页：" VerticalAlignment="Center" Width="180" />
                                    <local:ShortcutKeyBox ShortcutKey="{Binding Config.HomeKeyShortcut}" Width="200" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text="全屏：" VerticalAlignment="Center" Width="180" />
                                    <local:ShortcutKeyBox ShortcutKey="{Binding Config.FullscreenShortcut}" Width="200" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text="窗口1:1显示：" VerticalAlignment="Center" Width="180" />
                                    <local:ShortcutKeyBox ShortcutKey="{Binding Config.Window1x1Shortcut}" Width="200" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text="多任务：" VerticalAlignment="Center" Width="180" />
                                    <local:ShortcutKeyBox ShortcutKey="{Binding Config.RecentAppsShortcut}" Width="200" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text="音量+：" VerticalAlignment="Center" Width="180" />
                                    <local:ShortcutKeyBox ShortcutKey="{Binding Config.VolumeUpShortcut}" Width="200" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text="音量-：" VerticalAlignment="Center" Width="180" />
                                    <local:ShortcutKeyBox ShortcutKey="{Binding Config.VolumeDownShortcut}" Width="200" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text="旋转镜像：" VerticalAlignment="Center" Width="180" />
                                    <local:ShortcutKeyBox ShortcutKey="{Binding Config.RotateMirrorShortcut}" Width="200" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text="锁屏：" VerticalAlignment="Center" Width="180" />
                                    <local:ShortcutKeyBox ShortcutKey="{Binding Config.LockScreenShortcut}" Width="200" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text="亮屏：" VerticalAlignment="Center" Width="180" />
                                    <local:ShortcutKeyBox ShortcutKey="{Binding Config.TurnScreenOnShortcut}" Width="200" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text="关闭背光：" VerticalAlignment="Center" Width="180" />
                                    <local:ShortcutKeyBox ShortcutKey="{Binding Config.TurnScreenOffShortcut}" Width="200" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text="展开通知：" VerticalAlignment="Center" Width="180" />
                                    <local:ShortcutKeyBox ShortcutKey="{Binding Config.ExpandNotificationShortcut}" Width="200" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text="复制：" VerticalAlignment="Center" Width="180" />
                                    <local:ShortcutKeyBox ShortcutKey="{Binding Config.CopyShortcut}" Width="200" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text="粘贴：" VerticalAlignment="Center" Width="180" />
                                    <local:ShortcutKeyBox ShortcutKey="{Binding Config.PasteShortcut}" Width="200" />
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Grid.Row="4" Header="输入框设置" Margin="0,0,0,15">
                            <StackPanel Margin="10">
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text="传输模式：" VerticalAlignment="Center" Width="180" />
                                    <ComboBox SelectedValue="{Binding Config.TextTransferMode}" 
                                              SelectedValuePath="Tag"
                                              Width="200">
                                        <ComboBoxItem Content="文本注入法（推荐）" Tag="{x:Static models:TextTransferMode.TextInjection}" />
                                        <ComboBoxItem Content="复制粘贴法" Tag="{x:Static models:TextTransferMode.CopyPaste}" />
                                    </ComboBox>
                                </StackPanel>
                                <TextBlock Text="文本注入法：直接通过 scrcpy API 发送，不污染剪贴板" 
                                           FontSize="11" Foreground="Gray" Margin="0,0,0,10" />
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text="键盘监控间隔(ms)：" VerticalAlignment="Center" Width="180" />
                                    <TextBox Text="{Binding Config.KeyboardPollingInterval, UpdateSourceTrigger=PropertyChanged}" 
                                             Width="100" VerticalContentAlignment="Center" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text="键盘显示防抖(ms)：" VerticalAlignment="Center" Width="180" />
                                    <TextBox Text="{Binding Config.KeyboardShowDebounce, UpdateSourceTrigger=PropertyChanged}" 
                                             Width="100" VerticalContentAlignment="Center" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text="键盘隐藏防抖(ms)：" VerticalAlignment="Center" Width="180" />
                                    <TextBox Text="{Binding Config.KeyboardHideDebounce, UpdateSourceTrigger=PropertyChanged}" 
                                             Width="100" VerticalContentAlignment="Center" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text="位置更新间隔(ms)：" VerticalAlignment="Center" Width="180" />
                                    <TextBox Text="{Binding Config.PositionUpdateInterval, UpdateSourceTrigger=PropertyChanged}" 
                                             Width="100" VerticalContentAlignment="Center" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text="Scrcpy启动等待(ms)：" VerticalAlignment="Center" Width="180" />
                                    <TextBox Text="{Binding Config.ScrcpyStartupDelay, UpdateSourceTrigger=PropertyChanged}" 
                                             Width="100" VerticalContentAlignment="Center" />
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="保存配置" 
                                    Command="{Binding SaveConfigCommand}"
                                    Width="100" Margin="5" Padding="10,5" />
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <Grid Name="AboutPanel">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAboutPanelVisible}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSettingsPanelVisible}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <ScrollViewer>
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="关于" FontSize="16" FontWeight="Bold" Margin="0,0,0,20" />

                        <GroupBox Grid.Row="1" Header="应用信息" Margin="0,0,0,15">
                            <StackPanel Margin="10">
                                <TextBlock Text="Scrcpy GUI" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,5" />
                                <TextBlock Text="WPF 版 Android 设备投屏工具" FontSize="12" Foreground="Gray" HorizontalAlignment="Center" Margin="0,0,0,10" />
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Grid.Row="2" Header="版本信息" Margin="0,0,0,15">
                            <StackPanel Margin="10">
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text="版本号：" Width="100" />
                                    <TextBlock Text="1.0.0" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text="构建日期：" Width="100" />
                                    <TextBlock Text="2026-04-14" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text=".NET 版本：" Width="100" />
                                    <TextBlock Text="8.0" />
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Grid.Row="3" Header="版权信息" Margin="0,0,0,15">
                            <StackPanel Margin="10">
                                <TextBlock Text="Copyright © 52破解-YMXuan" Margin="0,5" />
                                <TextBlock Text="All rights reserved." Margin="0,5" />
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Grid.Row="4" Header="致谢" Margin="0,0,0,15">
                            <StackPanel Margin="10">
                                <TextBlock Text="本工具基于 scrcpy 项目开发" FontSize="12" />
                                <TextBlock Text="感谢 Genymobile 提供的 scrcpy 开源项目" FontSize="12" />
                                <TextBlock Text="https://github.com/Genymobile/scrcpy" FontSize="12" Foreground="Blue" Cursor="Hand" />
                                <TextBlock Text="感谢 晨钟酱 提供的 scrcpy_GUI项目" FontSize="12" />
                            </StackPanel>
                        </GroupBox>

                        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="🏠 返回主界面" 
                                    Command="{Binding GoBackToMainCommand}"
                                    Width="120" Margin="5" Padding="10,5" />
                        </StackPanel>

                    </Grid>
                </ScrollViewer>
            </Grid>
        </Grid>

        <GroupBox Header="日志" Grid.Row="2" Margin="5" Height="150">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBox Grid.Row="0" 
                         Text="{Binding LogText}" 
                         IsReadOnly="True" 
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="11"
                         Background="#F5F5F5" />
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                    <Button Content="清空日志" Command="{Binding ClearLogCommand}" Padding="10,3" />
                </StackPanel>
            </Grid>
        </GroupBox>
    </Grid>
</Window>