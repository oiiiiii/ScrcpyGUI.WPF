<Window x:Class="ScrcpyGUI.WPF.Views.WifiConnectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:ScrcpyGUI.WPF.ViewModels"
        mc:Ignorable="d"
        Title="无线连接" Height="300" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="无线连接设备" FontSize="16" FontWeight="Bold" Margin="0,0,0,20" />

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="设备IP地址：" Margin="0,0,0,5" />
            <TextBox x:Name="IpAddressTextBox" 
                     Text="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}"
                     Padding="8,5" />
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="端口号（默认5555）：" Margin="0,0,0,5" />
            <TextBox x:Name="PortTextBox" 
                     Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                     Padding="8,5" />
        </StackPanel>

        <TextBlock Grid.Row="3" 
                   x:Name="ErrorMessageTextBlock"
                   Text="{Binding ErrorMessage}"
                   Foreground="Red"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10" />

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="连接" 
                    Command="{Binding ConnectCommand}"
                    Width="100" Margin="5" Padding="10,5" />
            <Button Content="取消" 
                    Command="{Binding CancelCommand}"
                    Width="100" Margin="5" Padding="10,5" />
        </StackPanel>
    </Grid>
</Window>
