<Window x:Class="ScrcpyGUI.WPF.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:ScrcpyGUI.WPF.ViewModels"
        xmlns:local="clr-namespace:ScrcpyGUI.WPF.Views"
        mc:Ignorable="d"
        Title="设置" Height="780" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Scrcpy 路径设置" FontSize="16" FontWeight="Bold" Margin="0,0,0,20" />

        <GroupBox Grid.Row="1" Header="Scrcpy 可执行文件" Margin="0,0,0,15">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                
                <TextBox Grid.Row="0" Grid.Column="0" 
                         Text="{Binding ScrcpyPath, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,10,0" />
                <Button Grid.Row="0" Grid.Column="1" 
                        Content="浏览..." 
                        Command="{Binding BrowseScrcpyCommand}"
                        Padding="15,5" />
                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                           Text="{Binding ScrcpyPathError}"
                           Foreground="Red"
                           Margin="0,5,0,0" />
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="ADB 可执行文件" Margin="0,0,0,15">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                
                <TextBox Grid.Row="0" Grid.Column="0" 
                         Text="{Binding AdbPath, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,10,0" />
                <Button Grid.Row="0" Grid.Column="1" 
                        Content="浏览..." 
                        Command="{Binding BrowseAdbCommand}"
                        Padding="15,5" />
                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                           Text="{Binding AdbPathError}"
                           Foreground="Red"
                           Margin="0,5,0,0" />
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="3" Header="截图保存路径" Margin="0,0,0,15">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                
                <TextBox Grid.Column="0" 
                         Text="{Binding ScreenshotPath, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,10,0" />
                <Button Grid.Column="1" 
                        Content="浏览..." 
                        Command="{Binding BrowseScreenshotPathCommand}"
                        Padding="15,5" />
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="4" Header="其他设置" Margin="0,0,0,15">
            <StackPanel Margin="10">
                <CheckBox Content="启用智能输入悬浮窗" 
                          IsChecked="{Binding EnableFloatingWindow}"
                          Margin="0,5" />
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="5" Header="智能输入设置" Margin="0,0,0,15">
            <StackPanel Margin="10">
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <TextBlock Text="发送快捷键：" VerticalAlignment="Center" Width="100" />
                    <local:ShortcutKeyBox ShortcutKey="{Binding SendShortcutKey}" Width="200" />
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="6" Header="高级时间设置" Margin="0,0,0,15">
            <StackPanel Margin="10">
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <TextBlock Text="键盘监控间隔(ms)：" VerticalAlignment="Center" Width="150" />
                    <TextBox Text="{Binding KeyboardPollingInterval, UpdateSourceTrigger=PropertyChanged}" 
                             Width="100" VerticalContentAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <TextBlock Text="键盘显示防抖(ms)：" VerticalAlignment="Center" Width="150" />
                    <TextBox Text="{Binding KeyboardShowDebounce, UpdateSourceTrigger=PropertyChanged}" 
                             Width="100" VerticalContentAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <TextBlock Text="键盘隐藏防抖(ms)：" VerticalAlignment="Center" Width="150" />
                    <TextBox Text="{Binding KeyboardHideDebounce, UpdateSourceTrigger=PropertyChanged}" 
                             Width="100" VerticalContentAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <TextBlock Text="位置更新间隔(ms)：" VerticalAlignment="Center" Width="150" />
                    <TextBox Text="{Binding PositionUpdateInterval, UpdateSourceTrigger=PropertyChanged}" 
                             Width="100" VerticalContentAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <TextBlock Text="Scrcpy启动等待(ms)：" VerticalAlignment="Center" Width="150" />
                    <TextBox Text="{Binding ScrcpyStartupDelay, UpdateSourceTrigger=PropertyChanged}" 
                             Width="100" VerticalContentAlignment="Center" />
                </StackPanel>
                <Button Content="重置为默认值" 
                        Command="{Binding ResetTimingsCommand}"
                        HorizontalAlignment="Left"
                        Margin="0,10,0,0"
                        Padding="15,5" />
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="保存" 
                    Command="{Binding SaveCommand}"
                    Width="100" Margin="5" Padding="10,5" />
            <Button Content="取消" 
                    Command="{Binding CancelCommand}"
                    Width="100" Margin="5" Padding="10,5" />
        </StackPanel>
    </Grid>
</Window>